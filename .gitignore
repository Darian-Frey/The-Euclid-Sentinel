# ============================================================
# The Euclid Sentinel — .gitignore
# CODE-GEO V4.2 / Mimetic-Conformal Gravity Pipeline
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Testing & coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Runtime logs (generated, not committed) ──────────────────
sentinel_engine.log
*.log

# ── Generated survey outputs ─────────────────────────────────
# Produced by tools/run_full_survey.py and sparc_refinery_v4.py
# Regenerate from the pipeline — do not commit binary outputs
action_self_test_v42.png
mimetic_engine_v42_selftest.png
SENTINEL_REPORT_Bullet_Cluster_V42.png
DIAGNOSTIC_*_V42.png

# ── Old Phase VIII artefacts (archived, not tracked) ─────────
# These were generated by the deprecated pipeline with the
# hardcoded 12.0 DM factor. Scientifically invalid.
# Moved to archive/phase_08/ — excluded from active tracking.
SENTINEL_REPORT_Abell_370.png
SENTINEL_REPORT_Bullet_Cluster.png
SENTINEL_REPORT_El_Gordo.png
SENTINEL_REPORT_HUDF_DeepField.png
Sentinel_FINAL_REPORT.png

# ── Large data files (download separately) ───────────────────
# SPARC rotation curve database:
#   Download: https://zenodo.org/records/16284118
#   Extract to: data/sparc/
data/sparc/*.dat
data/sparc/*.zip
data/sparc/Rotmod_LTG.zip

# HST FITS data:
#   Download via: python3 tools/fetch_eso_data.py <target>
#   Or from MAST: https://mast.stsci.edu
data/raw_fits/
data/euclid_raw/

# ── Generated CSV results ────────────────────────────────────
# Regenerate from the pipeline — commit only if attaching to
# a specific paper version as supplementary material.
# To commit for a paper release: git add -f survey_outputs/SPARC_RESULTS_V42.csv
#survey_outputs/*.csv
#survey_outputs/*.png

